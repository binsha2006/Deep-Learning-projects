      "source": [
        "import torch\n",
        "tensor = torch.randn(5,4)\n",
        "print(\"Original Tensor:\\n\", tensor)\n",
        "print(\"\\nMean:\", tensor.mean())\n",
        "print(\"Max:\", tensor.max())\n",
        "print(\"Standard Deviation:\", tensor.std())\n",
        "reshaped_tensor = tensor.reshape(4, 5)\n",
        "print(\"\\nReshaped Tensor (4, 5):\\n\", reshaped_tensor)"
      ]
